# Public model pulls often work without a token.
# Set HF_TOKEN anyway to avoid rate limits and to make snapshot_download more reliable.
HF_TOKEN=

# Optional. setup_env.sh will export HUGGING_FACE_HUB_TOKEN from HF_TOKEN automatically.
HUGGING_FACE_HUB_TOKEN=

# Optional. Keep empty if you want local-only logging.
WANDB_API_KEY=

# Optional. Only needed if you explicitly switch any provider to OpenRouter.
OPENROUTER_API_KEY=

# Recommended defaults
HF_HUB_ENABLE_HF_TRANSFER=1
TOKENIZERS_PARALLELISM=false
WANDB_MODE=disabled
